{
  "name": "portfolio",
  "version": "0.9.0",
  "scripts": {
    "ng": "ng",
    "start:dev": "node ./set-env.dev.ts && ng serve --open",
    "start:stag": "node set-env.ts && ng serve --configuration staging",
    "start:prod": "node set-env.ts && ng serve --configuration production",
    "build": "ng build && npx serve dist/portfolio/browser",
    "build:stag": "node set-env.ts && ng build --configuration staging",
    "build:prod": "node set-env.ts && ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@10.9.0",
  "dependencies": {
    "@angular/common": "^21.2.7",
    "@angular/compiler": "^21.2.7",
    "@angular/core": "^21.2.7",
    "@angular/forms": "^21.2.7",
    "@angular/platform-browser": "^21.2.7",
    "@angular/router": "^21.2.7",
    "axios": "^1.14.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "underscore": "^1.13.8"
  },
  "devDependencies": {
    "@angular/build": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.7",
    "@types/node": "^25.5.0",
    "@types/underscore": "^1.13.0",
    "dotenv": "^17.3.1",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  },
  "overrides": {
    "vite": "^7.3.2"
  }
}
